{
	"nodes":[
		{"id":"g_timeline","type":"group","x":-80,"y":-250,"width":4000,"height":190,"label":"⏱ 시계열 — S1 금융감각 형성기 (7~9세)  |  민법 920조 · 친권자 완전 대리","color":"1"},
		{"id":"g_parent","type":"group","x":-80,"y":0,"width":4000,"height":560,"label":"👨‍👩‍👧 부모 역할 & 행동","color":"4"},
