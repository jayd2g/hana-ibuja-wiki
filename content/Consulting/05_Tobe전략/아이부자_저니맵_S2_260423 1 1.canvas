		{"id":"s1_entry","type":"text","text":"📌 **S1 진입**\n초등 입학 준비\n금융 교육 시작 결심","x":-3460,"y":330,"width":200,"height":124,"color":"2"},
		{"id":"s1_t2_2","type":"text","text":"🔵 앱 처음 열어봄\n'이게 내 앱이야?' 신기함\n[[D-4]] [[G-4]]","x":-2760,"y":140,"width":220,"height":124,"color":"5"},
