		{"id":"s1_t2_5","type":"text","text":"🟢 즉시 앱 이체\n📌 완료 현장","x":-1740,"y":225,"width":220,"height":80,"color":"4"},
		{"id":"s1_entry","type":"text","text":"📌 **S1 진입**\n초등 입학 준비\n금융 교육 시작 결심","x":-3460,"y":445,"width":200,"height":100,"color":"2"},
