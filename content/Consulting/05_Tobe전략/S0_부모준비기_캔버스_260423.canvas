		{"id":"C1","type":"text","x":30,"y":60,"width":150,"height":80,"text":"돈 = 물체\n첫 인식"},
		{"id":"C2","type":"text","x":220,"y":60,"width":150,"height":80,"text":"\"이거 사줘\"\n조르기 시작"},
		{"id":"C3","type":"text","x":420,"y":60,"width":160,"height":80,"text":"현금 받고\n다 써버림"},
		{"id":"C4","type":"text","x":630,"y":60,"width":160,"height":80,"text":"마트 결제\n구경·비교"},
		{"id":"C5","type":"text","x":1900,"y":60,"width":160,"height":80,"text":"저금통에\n동전 넣기"},
		{"id":"C6","type":"text","x":2840,"y":60,"width":170,"height":80,"text":"⭐ 돈이 늘고 있구나!\n첫 인지","color":"6"},
		{"id":"P1","type":"text","x":420,"y":320,"width":160,"height":80,"text":"현금 써버리는\n것 목격"},
