{
	"nodes":[
		{"id":"title","type":"text","x":0,"y":-280,"width":740,"height":90,"text":"# S0. 부모 준비기 — 출생~6세\n금융 개념 전무. 자녀는 앱 인지 없음. **부모만 움직인다.**","color":"6"},
		{"id":"legend","type":"text","x":780,"y":-280,"width":480,"height":90,"text":"🔵 자녀 행동 · 🟢 부모 행동\n📌 트리거(유입 계기) · ⭐ 핵심 경험\n─ 순서 흐름 · ┄ 파란선 = 부모↔자녀 연동"},
