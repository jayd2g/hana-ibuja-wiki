		{"id":"P3","type":"text","x":1100,"y":320,"width":190,"height":80,"text":"📌 세뱃돈 관리\n고민으로 검색","color":"3"},
		{"id":"P4","type":"text","x":1370,"y":320,"width":160,"height":80,"text":"아이부자 앱\n다운로드","color":"6"},
